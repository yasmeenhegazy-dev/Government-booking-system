# Copy this file to .env and fill in real values. Do NOT commit .env.

# --- Required in production ---
# MongoDB Atlas connection string (mongodb+srv://...)
# If unset locally, the backend falls back to mongodb-memory-server.
MONGODB_URI=

# Comma-separated list of origins the API will accept. In production set this
# to your Railway URL (e.g. https://gov-booking.up.railway.app).
ALLOWED_ORIGINS=http://localhost:3000

# production | development
NODE_ENV=development

# Express listens on this port. Railway provides PORT automatically.
PORT=5000

# --- Optional: email (booking confirmations + OTP) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
