# Copy to .env and fill in your values. Do NOT commit .env.

# MongoDB connection (leave blank to use the embedded mongodb-memory-server)
MONGODB_URI=

# Express port
PORT=5000

# production | development
NODE_ENV=development

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Optional — email (booking confirmations + OTP)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
